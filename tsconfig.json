{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "CommonJS",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
  ],
  "include": [
    "api",
    "lib"
  ]
}